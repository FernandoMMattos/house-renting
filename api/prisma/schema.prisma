// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String @id @default(cuid())
  email    String @unique
  name     String
  password String

  properties Property[]
}

model Property {
  id            String   @id @default(cuid())
  street        String
  number        Int
  areaCode      Int
  description   String
  eirCode       String
  propertyType  String
  roomType      String
  bedrooms      Int
  bathrooms     Int
  sharingWith   Int
  availableFrom DateTime
  availableFor  DateTime
  price         Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now())
  authorId      String
  isActive      Boolean  @default(true)
  image         Image[]
  author        User     @relation(fields: [authorId], references: [id])
}

model Image {
  id       String   @id @default(cuid())
  url      String
  publicId String
  houseId  String
  house    Property @relation(fields: [houseId], references: [id])
}
